#!/usr/bin/env bash
# Boot the nanowork entry site: frontend + backend

set -e
ROOT="$(cd "$(dirname "$0")" && pwd)"

# Install deps if needed
(cd "$ROOT/apps/frontend" && npm install 2>/dev/null || true)
(cd "$ROOT/apps/backend" && uv sync 2>/dev/null || true)
(cd "$ROOT/apps/generator" && uv sync 2>/dev/null || true)

# Kill child processes on exit
cleanup() {
  echo ""
  echo "Shutting down..."
  kill $(jobs -p) 2>/dev/null || true
  exit 0
}
trap cleanup SIGINT SIGTERM

echo "Starting backend (http://localhost:8000)..."
(cd "$ROOT/apps/backend" && uv run uvicorn app.main:app --reload --port 8000) &

echo "Starting frontend (http://localhost:5173)..."
(cd "$ROOT/apps/frontend" && npm run dev) &

wait
