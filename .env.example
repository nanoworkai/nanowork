# ========================================
# Nanowork Monorepo Environment Variables
# ========================================
# This file documents all environment variables used across the monorepo.
# Copy this file to .env and fill in your values.
#
# Each app has its own .env.example file with app-specific variables:
# - apps/web/.env.example (Frontend - Vite)
# - apps/worker/.dev.vars.example (Cloudflare Worker)
# - apps/backend/.env.example (Backend API - Express)
#
# For local development, you only need to set variables in the individual app directories.

# ========================================
# Global Configuration (Optional)
# ========================================
NODE_ENV=development

# ========================================
# Supabase (Required for all apps)
# ========================================
# Get these from: https://supabase.com/dashboard/project/[your-project]/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ========================================
# Anthropic API (Required for AI features)
# ========================================
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxx

# ========================================
# Stripe (Required for payments)
# ========================================
# Get these from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Stripe Product Price IDs (from Stripe Dashboard)
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_GROWTH=price_xxx
STRIPE_PRICE_SCALE=price_xxx
STRIPE_PRICE_ENTERPRISE=price_xxx
CUSTOM_DOMAIN_PRICE_ID=price_xxx

# ========================================
# Cloudflare (Required for worker and deployments)
# ========================================
# Get these from: https://dash.cloudflare.com/
CF_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token

# ========================================
# Application URLs
# ========================================
# Development URLs
VITE_API_URL=http://localhost:8787
VITE_SITE_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Production URLs (update for your deployment)
# VITE_API_URL=https://api.nanowork.ai
# VITE_SITE_URL=https://nanowork.ai
# FRONTEND_URL=https://nanowork.ai

# ========================================
# Security
# ========================================
INTERNAL_TOKEN=your-random-secure-token-here

# ========================================
# Agent Email Configuration (Optional)
# ========================================
AGENT_EMAIL_DOMAIN=your-agent-email-domain-here
