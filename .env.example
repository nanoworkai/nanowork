# ==============================================================================
# NANOWORK ENVIRONMENT VARIABLES
# ==============================================================================
# Copy this file to .env.local and fill in the values
# Never commit .env.local to git - it's in .gitignore

# ------------------------------------------------------------------------------
# DATABASE (Supabase)
# ------------------------------------------------------------------------------
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ------------------------------------------------------------------------------
# STRIPE CONFIGURATION
# ------------------------------------------------------------------------------
# Get these from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook secret for Stripe webhooks
# Get this from: https://dashboard.stripe.com/test/webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs for subscription plans
# Create these in Stripe Dashboard > Products
# Instructions below on how to create these
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_SCALE=price_...
STRIPE_PRICE_ENTERPRISE=price_...

VITE_STRIPE_PRICE_STARTER=price_...
VITE_STRIPE_PRICE_GROWTH=price_...
VITE_STRIPE_PRICE_SCALE=price_...
VITE_STRIPE_PRICE_ENTERPRISE=price_...

# ------------------------------------------------------------------------------
# API CONFIGURATION
# ------------------------------------------------------------------------------
VITE_API_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173
VITE_SITE_URL=http://localhost:5173

# ------------------------------------------------------------------------------
# SERVER CONFIGURATION
# ------------------------------------------------------------------------------
PORT=3000
NODE_ENV=development

# ==============================================================================
# STRIPE SETUP INSTRUCTIONS
# ==============================================================================
#
# 1. CREATE STRIPE ACCOUNT
#    - Go to https://stripe.com and create an account
#    - Switch to Test Mode (toggle in top right)
#
# 2. GET API KEYS
#    - Go to Developers > API keys
#    - Copy "Publishable key" and "Secret key"
#    - Add them to STRIPE_SECRET_KEY and STRIPE_PUBLISHABLE_KEY above
#
# 3. CREATE PRODUCTS & PRICES
#    - Go to Products > Add Product
#    - Create 4 products with recurring pricing:
#
#      Product 1: Starter Plan
#        - Name: Starter
#        - Description: Full company built and running
#        - Price: $99/month
#        - Copy the price ID (starts with price_) to STRIPE_PRICE_STARTER
#
#      Product 2: Growth Plan
#        - Name: Growth
#        - Description: Scaling with more power
#        - Price: $249/month
#        - Copy the price ID to STRIPE_PRICE_GROWTH
#
#      Product 3: Scale Plan
#        - Name: Scale
#        - Description: Enterprise-grade, unlimited
#        - Price: $499/month
#        - Copy the price ID to STRIPE_PRICE_SCALE
#
#      Product 4: Enterprise Plan
#        - Name: Enterprise
#        - Description: Custom enterprise solution
#        - Price: Contact for pricing (or set custom amount)
#        - Copy the price ID to STRIPE_PRICE_ENTERPRISE
#
# 4. SETUP WEBHOOKS
#    - Go to Developers > Webhooks
#    - Click "Add endpoint"
#    - Endpoint URL: https://your-domain.com/api/wallet/webhook
#      (For local testing: use Stripe CLI or ngrok)
#    - Select events to listen to:
#      ✓ customer.subscription.created
#      ✓ customer.subscription.updated
#      ✓ customer.subscription.deleted
#      ✓ invoice.payment_succeeded
#      ✓ invoice.payment_failed
#    - Copy the "Signing secret" to STRIPE_WEBHOOK_SECRET
#
# 5. LOCAL TESTING WITH STRIPE CLI (OPTIONAL)
#    - Install: https://stripe.com/docs/stripe-cli
#    - Login: stripe login
#    - Forward webhooks: stripe listen --forward-to localhost:3000/api/wallet/webhook
#    - Copy the webhook signing secret from the output
#
# 6. TESTING PAYMENT
#    - Use test card: 4242 4242 4242 4242
#    - Any future expiry date (e.g., 12/34)
#    - Any 3-digit CVC
#    - Any ZIP code
#
# ==============================================================================
