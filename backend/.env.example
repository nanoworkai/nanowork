# Supabase Configuration
SUPABASE_URL=your-supabase-project-url
SUPABASE_SERVICE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here

# Server Configuration
PORT=3000
FRONTEND_URL=http://localhost:5173

# Anthropic API Configuration
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Stripe Configuration
STRIPE_SECRET_KEY=your-stripe-secret-key-here
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret-here
CUSTOM_DOMAIN_PRICE_ID=your-stripe-custom-domain-price-id-here

# Stripe Product Price IDs
STRIPE_PRICE_STARTER=your-stripe-starter-price-id-here
STRIPE_PRICE_GROWTH=your-stripe-growth-price-id-here
STRIPE_PRICE_SCALE=your-stripe-scale-price-id-here
STRIPE_PRICE_ENTERPRISE=your-stripe-enterprise-price-id-here

# Agent Email Configuration
AGENT_EMAIL_DOMAIN=your-agent-email-domain-here

# Internal Security Token
INTERNAL_TOKEN=your-internal-security-token-here

# Cloudflare Configuration
CF_ACCOUNT_ID=your-cloudflare-account-id-here
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token-here
