# ========================================
# Frontend (apps/web) Environment Variables
# ========================================
# Copy this file to .env.local and fill in your values.
# These variables are prefixed with VITE_ to be accessible in the browser.

# ========================================
# API Configuration
# ========================================
# Local development: Leave empty to use Vite dev server proxy
# Or point to local worker: http://localhost:8787
# Production: https://api.nanowork.ai (your Cloudflare Worker URL)
VITE_API_URL=

# ========================================
# Site URL
# ========================================
# Used for auth redirects and callbacks
# Local: http://localhost:5173
# Production: https://nanowork.ai
VITE_SITE_URL=http://localhost:5173

# ========================================
# Supabase Configuration
# ========================================
# Get these from: https://supabase.com/dashboard/project/[your-project]/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ========================================
# Stripe Configuration (Optional)
# ========================================
# Get your publishable key from: https://dashboard.stripe.com/apikeys
# Use test key (pk_test_) for development, live key (pk_live_) for production
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
