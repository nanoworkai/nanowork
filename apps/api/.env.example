ENVIRONMENT=development

# Anthropic (gallery /api/ai live responses)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# Supabase (server-side client; omit to run without DB)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated browser origins allowed to call the API directly (needed when SPA uses VITE_API_BASE_URL)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
