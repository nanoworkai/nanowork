{
  "name": "nanowork-mvp",
  "private": true,
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:worker\"",
    "dev:web": "npm run dev -w web",
    "dev:worker": "cd apps/worker && npx wrangler dev",
    "build": "npm run build -w web",
    "deploy": "npm run build && npm run deploy:worker && npm run deploy:web",
    "deploy:worker": "cd apps/worker && npx wrangler deploy",
    "deploy:web": "cd apps/web && npx wrangler pages deploy dist"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
