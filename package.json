{
  "name": "nanowork-mvp",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "cd apps/web && bun run dev",
    "dev:worker": "cd apps/worker && npx wrangler dev",
    "dev:backend": "cd apps/backend && npm run dev",
    "build": "turbo build",
    "build:web": "cd apps/web && bun run build",
    "build:worker": "cd apps/worker && npm run build",
    "build:backend": "cd apps/backend && npm run build",
    "start": "npm run start -w web",
    "deploy": "npm run deploy:worker",
    "deploy:worker": "cd apps/worker && npx wrangler deploy",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "validate": "turbo typecheck && turbo lint",
    "prepare": "simple-git-hooks",
    "generate:og": "bun scripts/generate-og-image.js"
  },
  "dependencies": {
    "serve": "^14.2.4"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "lint-staged": "^15.2.11",
    "playwright": "^1.60.0",
    "simple-git-hooks": "^2.12.1",
    "turbo": "^2.9.16"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "apps/worker/src/**/*.ts": [
      "cd apps/worker && npm run typecheck",
      "cd apps/worker && npm run lint"
    ],
    "apps/web/src/**/*.{ts,tsx}": [
      "cd apps/web && tsc --noEmit"
    ]
  },
  "packageManager": "npm@10.8.2"
}
