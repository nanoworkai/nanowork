{
  "name": "nanowork-mvp",
  "private": true,
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev": "npm run dev -w web",
    "build": "npm run build -w web",
    "preview": "npm run preview -w web",
    "dev:api": "bash -lc 'cd apps/api && PYTHONPATH=. .venv/bin/python -m uvicorn app.main:app --reload --host 127.0.0.1 --port 8000'",
    "dev:worker": "cd apps/worker && npx wrangler dev",
    "deploy:worker": "cd apps/worker && npx wrangler deploy"
  }
}
